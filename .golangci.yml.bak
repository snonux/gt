# golangci-lint configuration for perc project

linters:
  enable:
    - gofmt
    - goimports
    - govet
    - errcheck
    - staticcheck
    - unused
    - gosimple
    - structcheck
    - varcheck
    - ineffassign
    - deadcode
    - typecheck

linters-settings:
  goimports:
    local-prefixes: codeberg.org/snonux/perc
  errcheck:
    check-blank: false

run:
  timeout: 5m
